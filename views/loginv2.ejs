<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Ordem de Serviço</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-indigo-200 via-purple-100 to-indigo-100 min-h-screen flex items-center justify-center">

  <div class="bg-white w-full max-w-md rounded-2xl p-8 border border-gray-200">

    <!-- Logo / Título -->
    <div class="text-center mb-6">
      <div class="text-indigo-600 text-4xl mb-2">🛠️</div>
      <h1 class="text-2xl font-bold text-gray-700">Ordem de Serviço</h1>
      <p class="text-gray-400 text-sm">Acesse sua conta</p>
    </div>
<form id="formAuthentication" class="space-y-4" action="javascript:func()" method="post">
    

      <div>
        <label class="text-sm text-gray-600">Email</label>
        <input
          type="email"
		  id="email"
          placeholder="seuemail@email.com"
          class="w-full mt-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 outline-none"
        />
      </div>

      <div>
        <label class="text-sm text-gray-600">Senha</label>
        <div class="relative mt-1">
          <input
            id="senha"
            type="password"
            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 outline-none"
          />
          <button
            type="button"
            onclick="toggleSenha()"
            class="absolute right-3 top-2 text-gray-400"
          >
            👁️
          </button>
        </div>
      </div>

      <div class="flex items-center justify-between text-sm">
        <label class="flex items-center gap-2">
          <input type="checkbox" class="accent-indigo-500">
          Lembrar-me
        </label>

        <a href="#" class="text-indigo-500 hover:underline">
          Esqueci a senha
        </a>
      </div>
		<div id="msg" class="hidden text-center text-green-600 text-sm font-semibold">
		  Login efetuado com sucesso!
		</div>

      <button id="logar"
        class="w-full bg-indigo-500 hover:bg-indigo-600 text-white py-2 rounded-lg font-semibold transition"
      >
        Entrar
      </button>

    </form>

  </div>
<script src="../assets/vendor/libs/jquery/jquery.js"></script>
<script>
function toggleSenha() {
  const input = document.getElementById("senha");
  input.type = input.type === "password" ? "text" : "password";
}

$("#logar").click(function(){

	let email = $("#email").val();
	let senha = $("#senha").val();	

	const btn = $("#logar");
	const card = btn.closest("div.bg-white");

	$.post('/login', {
		email: email,
		senha: senha
	}, function(resposta) {
		
		if(resposta != "Usuário ou senha inválidos"){

			btn.prop("disabled", true);
			btn.html("Entrando...");

			$("#msg").removeClass("hidden");

			setTimeout(() => {
				card.css({
					transition: "all 0.5s ease",
					transform: "scale(0.95)",
					opacity: "0"
				});

				setTimeout(() => {
					window.location.href = "/principal/" + resposta;
				}, 500);

			}, 800);

		}else{
			alert(resposta);
		}
	});
});
</script>

</script>


</body>
</html>
