	function concluirOrdemServico(idOrdemServico){
		//alert(idOrdemServico);
		if (confirm("Confirma a Finalização da Ordem de Serviço?")) {
			$.post('/finalizarOrdemServico', {
				idOrdemServico: idOrdemServico			
